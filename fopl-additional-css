/* ---- Through the lens + NRM lockup (#block-19) ----
   IMPORTANT / why this is written the way it is:
   Kadence regenerates every hashed class inside this block (.kb-image...,
   .kb-row-layout-id..., .kt-adv-heading...) whenever you swap an image or
   re-save the row. That has already broken this section twice. The section
   widget id (#block-19) is STABLE, so from now on everything is anchored to
   #block-19 + structural selectors (.kt-has-4-columns, :first-child /
   :last-child, figure.wp-block-kadence-image). Do NOT reintroduce the hashed
   classes here; if you swap the lens photos again this will keep working.
     lens grid            #block-19 .kt-row-column-wrap.kt-has-4-columns
     lens photos          #block-19 .kt-has-4-columns figure.wp-block-kadence-image
     "Through the lens"   #block-19 lens column > heading
     NRM funder text      #block-19 last column .wp-block-kadence-advancedheading
     NRM logo             #block-19 last column figure.wp-block-kadence-image */

/* Outer row padding trim (keeps the 2-col lens|NRM split from the markup) */
#block-19 > .kb-row-layout-wrap > .kt-row-column-wrap {
  padding-top: 6px !important;
  padding-bottom: 10px !important;
}
/* "Through the lens" label spacing above the grid */
#block-19 > .kb-row-layout-wrap > .kt-row-column-wrap
  > .wp-block-kadence-column:first-child
  > .kt-inside-inner-col > .wp-block-kadence-advancedheading {
  margin-bottom: 14px !important;
}

/* LENS GRID: uniform 3:2 thumbnails, 6px radius, even gap.
   The markup sizes its 4 columns with a calc() tuned to the theme's 2rem gap,
   so a bare gap change would leave dead space on the right. Overriding to a
   clean repeat(4, 1fr) lets the columns re-fit the gap. */
#block-19 .kt-row-column-wrap.kt-has-4-columns {
  grid-template-columns: repeat(4, minmax(0, 1fr)) !important;
  column-gap: 10px !important;
  row-gap: 10px !important;
  padding-top: 5px !important;
}
@media (min-width: 768px) and (max-width: 1024px) {
  #block-19 .kt-row-column-wrap.kt-has-4-columns {
    column-gap: 12px !important;
    row-gap: 12px !important;
  }
}
