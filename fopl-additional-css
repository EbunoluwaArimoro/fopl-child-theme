@import url('https://fonts.googleapis.com/css2?family=Lato:wght@400;500;700;900&family=Merriweather:ital,wght@0,400;0,700;0,900;1,400&display=swap');

/* -------------------------------------------------------------------------
   1. DESIGN TOKENS  (canonical set from index.html :root)
   ------------------------------------------------------------------------- */
:root{
  --deep-teal:#0E4C59;
  --fresh-teal:#4FA3A5;
  --golden-sedge:#C4A35A;
  --reed-white:#F0F4EF;
  --charcoal:#243033;
  --slate:#5F6B70;
  --stone:#D8D3CC;
  --dark-ochre:#3D2E0A;
  --lake-blue:#1F6F8B;
  --reed-green:#6B8F71;
  --sedge-rust:#C4734A;
  --waterline:#7A8C96;
  --green-15:#E9EFEA;
  --rust-15:#F6E8E1;
  --teal-15:#E4F0F0;
  --gold-15:#F5EDDB;
  --water-15:#EAEDEF;
  --display:"Merriweather", Georgia, serif;
  --sans:"Lato", system-ui, -apple-system, "Segoe UI", sans-serif;
  --wrap:1240px;
  --gutter:clamp(20px, 4vw, 40px);
}

/* -------------------------------------------------------------------------
   2. BASE
   ------------------------------------------------------------------------- */
body{
  font-family:var(--sans);
  font-size:17px;
  line-height:1.65;
  color:var(--charcoal);
  background:var(--reed-white);
  -webkit-font-smoothing:antialiased;
  text-rendering:optimizeLegibility;
}
h1,h2,h3,h4{font-family:var(--display); font-weight:700; color:var(--deep-teal); margin:0; letter-spacing:-.01em}
h1{font-size:clamp(40px, 5.6vw, 76px); line-height:1.05}
h2{font-size:clamp(30px, 3.4vw, 44px); line-height:1.15}
h3{font-family:var(--sans); font-weight:700; font-size:20px; line-height:1.3; color:var(--charcoal); letter-spacing:0}

/* -------------------------------------------------------------------------
   3. TEXT UTILITIES
   ------------------------------------------------------------------------- */
.eyebrow{font-family:var(--sans); font-weight:700; font-size:12px; letter-spacing:.22em; text-transform:uppercase; color:var(--fresh-teal)}
.eyebrow--dark{color:var(--deep-teal)}
.eyebrow--slate{color:var(--slate)}
.lead{font-size:19px; line-height:1.55; color:var(--charcoal)}
.lead--slate{color:var(--slate); font-size:17px; max-width:620px}
.caption{font-family:var(--display); font-style:italic; font-size:12px; color:var(--slate); letter-spacing:.03em; margin-top:10px}
.caption--on-dark{color:rgba(240,244,239,.7)}
.pull-quote{border-left:3px solid var(--fresh-teal); background:var(--teal-15); padding:1.1rem 1.5rem; margin:2rem 0; border-radius:0 3px 3px 0}
.pull-quote p{font-family:var(--display); font-style:italic; font-size:1.1rem; line-height:1.65; color:var(--deep-teal); margin:0}
.sci-name{font-family:var(--display); font-style:italic; font-weight:400; color:var(--slate)}
.sci-name--sm{font-size:12.5px}
.sci-name--lg{font-size:20px}
.card-title{font-family:var(--display); font-weight:700; font-size:22px; line-height:1.25; color:var(--deep-teal); letter-spacing:-.01em}

/* -------------------------------------------------------------------------
   4. BUTTONS
   ------------------------------------------------------------------------- */
.btn{
  display:inline-flex; align-items:center; gap:8px;
  font-family:var(--sans); font-weight:700; font-size:15px;
  padding:12px 22px; border-radius:4px; text-decoration:none;
  border:2px solid transparent; cursor:pointer; line-height:1;
  transition:background .18s, color .18s, border-color .18s, transform .08s;
}
.btn:active{transform:translateY(1px)}
.btn--primary{background:var(--deep-teal); color:#fff; border-color:var(--deep-teal)}
.btn--primary:hover{background:#0a3d48; border-color:#0a3d48}
.btn--featured{background:var(--golden-sedge); color:var(--dark-ochre); border-color:var(--golden-sedge)}
.btn--featured:hover{background:#b89349; border-color:#b89349}
.btn--ghost{background:transparent; color:var(--deep-teal); border-color:var(--deep-teal)}
.btn--ghost:hover{background:var(--deep-teal); color:#fff}
.btn--ghost-light{background:transparent; color:#fff; border-color:rgba(255,255,255,.8)}
.btn--ghost-light:hover{background:#fff; color:var(--deep-teal); border-color:#fff}
.btn--primary.btn--on-dark{background:#fff; color:var(--deep-teal); border-color:#fff}
.btn--primary.btn--on-dark:hover{background:var(--fresh-teal); color:#fff; border-color:var(--fresh-teal)}
.btn--sm{padding:9px 16px; font-size:14px}

/* -------------------------------------------------------------------------
   5. SECTION HEADER
   ------------------------------------------------------------------------- */
.section__head{display:grid; grid-template-columns:1fr auto; gap:24px; align-items:end; margin-bottom:48px}
.section__head .headgroup{max-width:720px}
.section__head h2{margin-top:10px}
.section__head p{margin:10px 0 0; color:var(--slate); max-width:620px; font-size:17px}

/* -------------------------------------------------------------------------
   6. CONTENT CARD + GRID
   ------------------------------------------------------------------------- */
.news__grid{display:grid; grid-template-columns:repeat(3,1fr); gap:24px}
.card{background:#fff; border:1px solid var(--stone); display:flex; flex-direction:column; overflow:hidden; transition:transform .18s, box-shadow .18s}
.card:hover{transform:translateY(-3px); box-shadow:0 18px 40px -24px rgba(14,76,89,.25)}
.card__photo{aspect-ratio:16/10; background-size:cover; background-position:center; position:relative}
.card__cat{position:absolute; top:0; left:0; font-size:11px; letter-spacing:.16em; text-transform:uppercase; font-weight:900; padding:7px 14px; background:var(--cat, var(--deep-teal)); color:#fff}
.card__body{padding:22px 24px 26px; flex:1; display:flex; flex-direction:column}
.card p{color:var(--slate); font-size:15px; line-height:1.55; margin:0 0 16px}
.card__more{margin-top:auto; color:var(--lake-blue); font-weight:700; font-size:14px}
.card--water{--cat:var(--fresh-teal)}
.card--habitat{--cat:var(--reed-green)}
.card--community{--cat:var(--sedge-rust)}

/* -------------------------------------------------------------------------
   7. SPECIES CARD bits
   ------------------------------------------------------------------------- */
.card__top{display:flex; align-items:flex-start; justify-content:space-between; gap:10px; margin-bottom:6px}
.card__name{font-family:var(--sans); font-weight:700; font-size:16px; color:var(--charcoal)}
.card__desc{font-size:13.5px; color:var(--slate); line-height:1.5}

/* -------------------------------------------------------------------------
   8. BADGES
   ------------------------------------------------------------------------- */
.badge{font-family:var(--sans); font-weight:700; font-size:10px; letter-spacing:.14em; text-transform:uppercase; padding:4px 9px; border-radius:3px; display:inline-block}
.badge--birds{background:#DCE9EA; color:#0E4C59}
.badge--reptiles{background:#E0E8E0; color:#3D5942}
.badge--mammals{background:#F2E7CD; color:#5C4416}
.badge--invertebrates{background:#E2E6E9; color:#3F4B52}
.badge--amphibians{background:#D8E2EB; color:#163C52}
.statusbadge--vulnerable{background:var(--sedge-rust); color:#fff}
.statusbadge--endangered{background:#9E4A2C; color:#fff}
.statusbadge--least-concern{background:var(--reed-green); color:#fff}

/* -------------------------------------------------------------------------
   9. STAT / METRIC BARS
   ------------------------------------------------------------------------- */
.stats__inner{display:grid; grid-template-columns:repeat(3,1fr); gap:40px}
.stat__num{font-family:var(--display); font-weight:700; color:var(--deep-teal); font-size:clamp(30px,3.4vw,46px); line-height:1; letter-spacing:-.02em}
.stat__num small{font-size:.5em; font-weight:700}
.stat__label{font-size:13.5px; color:var(--slate); line-height:1.45; margin-top:12px}
.metric{background:var(--deep-teal); color:var(--reed-white); border-radius:8px; padding:24px 22px}
.metric__num{font-family:var(--display); font-weight:700; font-size:32px; line-height:1; letter-spacing:-.01em}
.metric__num small{font-size:.45em; font-weight:700; opacity:.85}
.metric__label{font-size:12.5px; line-height:1.45; color:rgba(240,244,239,.78); margin-top:10px}
.metric--wide{grid-column:1 / -1; background:#fff; border:1px solid var(--stone); color:var(--charcoal)}
.metric--wide .metric__num{color:var(--deep-teal)}
.metric--wide .metric__label{color:var(--slate)}

/* -------------------------------------------------------------------------
   10. CTA BAND  (class on a Row: join)
   ------------------------------------------------------------------------- */
.join{background:linear-gradient(120deg,#0E4C59 0%,#0a3d48 100%)}
.join__inner{position:relative; display:grid; grid-template-columns:1.4fr auto; gap:64px; align-items:center}
.join .eyebrow{color:var(--fresh-teal); margin-bottom:14px}
.join h2{color:#fff; margin-bottom:14px; max-width:620px; text-wrap:balance}
.join p{color:rgba(255,255,255,.82); font-size:17px; line-height:1.55; margin:0 0 24px; max-width:580px}

/* -------------------------------------------------------------------------
   11. INTERIOR PAGE HERO (base tokens, kept as-is; not touched this pass.
       These predate the fuller "INTERIOR HERO (global)" block further down
       and may or may not still be in active use on any page, worth a
       quick check next time you're auditing, but out of scope for this
       Through the Lens cleanup so I left them alone.)
   ------------------------------------------------------------------------- */
.hero__overlay{background:linear-gradient(180deg,rgba(14,76,89,.50) 0%,rgba(14,76,89,.72) 100%)}
.hero__inner{max-width:880px; padding:104px 0 64px}
.hero h1{text-shadow:0 2px 22px rgba(8,30,35,.38)}
.hero__credit{position:absolute; right:var(--gutter); bottom:58px; font-family:var(--display); font-style:italic; font-size:12px; color:rgba(240,244,239,.7); letter-spacing:.03em}

/* =========================================================================
   12. RESPONSIVE (base type scale / homepage components)
   ========================================================================= */
@media (max-width:1020px){
  .section__head{grid-template-columns:1fr}
  .news__grid{grid-template-columns:1fr; gap:20px}
  .stats__inner{grid-template-columns:repeat(2,1fr); gap:28px}
  .join__inner{grid-template-columns:1fr; gap:44px}
  .hero__inner{padding:80px 0 56px}
}
@media (max-width:640px){
  .lead{font-size:18px}
  .pull-quote{padding:.9rem 1.1rem}
  .stats__inner{grid-template-columns:1fr; gap:20px}
  .hero__inner{padding:64px 0 48px}
}

